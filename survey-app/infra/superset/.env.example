# Скопируйте в .env и задайте свои значения.

SUPERSET_PORT=8088

# Обязательно смените в проде: openssl rand -hex 32
SUPERSET_SECRET_KEY=

# Учётная запись администратора Superset (не путать с пользователями приложения «Пульс»)
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_EMAIL=admin@example.local
SUPERSET_ADMIN_PASSWORD=change-me-strong

# Внутренний Postgres только для метаданных Superset (дашборды, пользователи BI)
SUPERSET_META_USER=superset
SUPERSET_META_PASSWORD=superset_meta_change_me
SUPERSET_META_DB=superset
