# Пример переменных для Cloud Function (Яндекс и др.).
# Скопируйте в .env.cloud-function в корне survey-app (файл в .gitignore)
# или задайте export перед ./scripts/publish-function-yandex.sh publish
#
# Обязательные для API:
# PG_CONNECTION_STRING=postgresql://user:pass@host:6432/dbname?sslmode=require
# ADMIN_API_KEY=длинный-секрет-для-X-Api-Key
# CORS_ORIGIN=https://ваш-сайт.website.yandexcloud.net

# ——— SMTP (приглашения к опросу, педагогические отчёты и др.) ———
# Без этих переменных isSmtpConfigured=false, GET /api/ping покажет smtp_configured: false.
#
# Яндекс 360 / корпоративная почта (часто порт 465 + SSL):
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_SECURE=1
# SMTP_USER=noreply@ваш-домен.ru
# SMTP_PASS=пароль-приложения-или-основной
# SMTP_FROM="Пульс <noreply@ваш-домен.ru>"
#
# Тот же Яндекс через 587 + STARTTLS:
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_REQUIRE_TLS=1
# SMTP_USER=...
# SMTP_PASS=...
# SMTP_FROM="Пульс <noreply@...>"
#
# Отключить принудительный STARTTLS на 587 (редко нужно):
# SMTP_REQUIRE_TLS=0
#
# Только отладка при ошибках сертификата (в проде не включать):
# SMTP_TLS_REJECT_UNAUTHORIZED=0
#
# Таймаут подключения к SMTP, мс (по умолчанию 20000):
# SMTP_CONNECTION_TIMEOUT_MS=20000

# ——— LLM (OpenRouter / OpenAI и др.) ———
# Основная модель и запасные через запятую при 429 / Forbidden / лимите free-tier:
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-4o-mini
# OPENAI_MODEL_FALLBACKS=google/gemini-2.0-flash-001,meta-llama/llama-3.3-70b-instruct
# (альтернативное имя: LLM_MODEL_FALLBACKS)
